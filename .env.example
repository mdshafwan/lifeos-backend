# ═══════════════════════════════════════════
# LIFEOS BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in values
# ═══════════════════════════════════════════

# ── App Settings ────────────────────────────
APP_NAME=LifeOS Backend
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ── Server ──────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ────────────────────────────────
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/lifeos_db

# ── JWT Settings ────────────────────────────
SECRET_KEY=af289f7df65af71787692b3f490522b2f2f06fd9c6368099d95590361483d3769f348dad849dfee10d16c00b588896b05f0dde51355a2e9cf35974a63aebf02e
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ── File Storage ────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Ollama (AI) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Email (SMTP) ────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ── Gamification ────────────────────────────
XP_TASK_COMPLETE=10
XP_HABIT_COMPLETE=15
XP_GOAL_COMPLETE=100
XP_JOURNAL_ENTRY=5
XP_LOGIN_STREAK=20